# --- MONEY MENTOR UNIFIED IGNORE ---

# Node.js / Next.js (Frontend)
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# Python (Backend)
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/.env
backend/venv/
backend/env/
backend/pip-log.txt
backend/pip-delete-this-directory.txt

# Database (Local)
data/db/
*.log

# Environment Files (Sensitive)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDEs / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Misc
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
