# --- Money Mentor Backend Environment Variables ---
# Copy this file to .env and fill in your real credentials

PROJECT_NAME="Money Mentor - AI Personal Finance"
MONGO_URI="mongodb+srv://<username>:<password>@cluster.mongodb.net/finance_ai"
DATABASE_NAME="finance_ai"
SECRET_KEY="your-secret-key-change-me"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080
GROQ_API_KEY="your-groq-api-key-here"
